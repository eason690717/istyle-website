// i時代 — 板橋手機維修 / 自建電商
// Schema: 維修報價引擎 + 訂單 + 預約 + 後台

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ============================================================
// 維修目錄
// ============================================================

model Brand {
  id          Int           @id @default(autoincrement())
  slug        String        @unique
  name        String
  nameZh      String
  iconUrl     String?
  sortOrder   Int           @default(0)
  isActive    Boolean       @default(true)
  models      DeviceModel[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model DeviceModel {
  id          Int           @id @default(autoincrement())
  brandId     Int
  brand       Brand         @relation(fields: [brandId], references: [id])
  slug        String        @unique
  name        String
  section     String?
  searchKeywords String?
  imageUrl    String?
  sortOrder   Int           @default(0)
  isActive    Boolean       @default(true)
  prices      RepairPrice[]
  bookings    Booking[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([brandId])
}

model RepairItem {
  id             Int           @id @default(autoincrement())
  slug           String        @unique
  name           String
  nameEn         String?
  description    String?
  category       String?
  estimatedHours Float?
  warrantyMonths Int?
  sortOrder      Int           @default(0)
  isActive       Boolean       @default(true)
  prices         RepairPrice[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model RepairPrice {
  id                Int         @id @default(autoincrement())
  modelId           Int
  model             DeviceModel @relation(fields: [modelId], references: [id])
  itemId            Int
  item              RepairItem  @relation(fields: [itemId], references: [id])
  tier              String      // "STANDARD" | "OEM"
  cerphonePriceRaw  String?
  cerphonePrice     Int?
  calculatedPrice   Int?
  manualOverride    Int?
  partsCost         Int?
  outsourceCost     Int?
  laborCost         Int?
  isAvailable       Boolean     @default(true)
  notes             String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@unique([modelId, itemId, tier])
  @@index([modelId])
  @@index([itemId])
}

// ============================================================
// 客戶 / 訂單
// ============================================================

model Customer {
  id          Int       @id @default(autoincrement())
  name        String
  phone       String
  email       String?
  lineId      String?
  notes       String?
  orders      Order[]
  bookings    Booking[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([phone])
}

model Order {
  id              Int          @id @default(autoincrement())
  orderNumber     String       @unique
  customerId      Int?
  customer        Customer?    @relation(fields: [customerId], references: [id])
  contactName     String
  contactPhone    String
  contactEmail    String?
  shippingMethod  String       @default("IN_STORE")  // IN_STORE | CVS_711 | HOME
  shippingAddress String?
  shippingFee     Int          @default(0)
  subtotal        Int
  total           Int
  status          String       @default("PENDING")    // PENDING | CONFIRMED | IN_REPAIR | COMPLETED | CANCELLED
  paymentStatus   String       @default("UNPAID")     // UNPAID | PAID | REFUNDED
  paymentMethod   String?
  ecpayTradeNo    String?      @unique
  invoiceNumber   String?
  customerNote    String?
  internalNote    String?
  bookingId       Int?         @unique
  booking         Booking?     @relation(fields: [bookingId], references: [id])
  items           OrderItem[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  paidAt          DateTime?
  completedAt     DateTime?

  @@index([customerId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id              Int      @id @default(autoincrement())
  orderId         Int
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  modelName       String
  itemName        String
  tier            String
  unitPrice       Int
  quantity        Int      @default(1)
  subtotal        Int
  priceAdjustment Int      @default(0)
  adjustmentReason String?
  repairStatus    String   @default("PENDING")  // PENDING | IN_PROGRESS | DONE | ISSUE
  partsCostAtTime Int?
  internalNote    String?

  @@index([orderId])
}

// ============================================================
// 預約
// ============================================================

model Booking {
  id            Int          @id @default(autoincrement())
  bookingNumber String       @unique
  customerId    Int?
  customer      Customer?    @relation(fields: [customerId], references: [id])
  serviceType   String       // REPAIR | RECYCLE | DIAGNOSTIC | COURSE_INQUIRY | GENERAL
  modelId       Int?
  model         DeviceModel? @relation(fields: [modelId], references: [id])
  itemIds       String?      // JSON array
  description   String?
  contactName   String
  contactPhone  String
  contactEmail  String?
  contactLine   String?
  scheduledDate DateTime
  scheduledTime String       // "14:00"
  status        String       @default("PENDING")  // PENDING | CONFIRMED | COMPLETED | CANCELLED | NO_SHOW
  cancelReason  String?
  order         Order?
  internalNote  String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  confirmedAt   DateTime?
  completedAt   DateTime?

  @@index([scheduledDate])
  @@index([status])
}

// ============================================================
// 後台
// ============================================================

model User {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  name          String?
  role          String   @default("ADMIN")  // ADMIN | STAFF
  emailVerified DateTime?
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ============================================================
// 付款連結（老闆產生 → LINE 給客戶 → 客戶付款）
// ============================================================
model PaymentLink {
  id              Int       @id @default(autoincrement())
  token           String    @unique  // 公開 URL token
  amount          Int       // 金額 NTD
  itemName        String    // 商品/服務名稱
  description     String?
  customerName    String?
  customerPhone   String?
  customerEmail   String?
  // 連動訂單
  orderId         Int?      @unique
  // ECPay 相關
  ecpayTradeNo    String?   @unique
  ecpayMerchantTradeNo String? @unique
  paymentMethod   String?
  paidAt          DateTime?
  // 發票
  invoiceNumber   String?
  invoiceIssuedAt DateTime?
  // 狀態
  status          String    @default("PENDING")  // PENDING | PAID | EXPIRED | CANCELLED
  expiresAt       DateTime?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status])
  @@index([createdAt])
}

// ============================================================
// 後台 Session + 登入嘗試（防爆破）
// ============================================================
model AdminSession {
  id          Int       @id @default(autoincrement())
  token       String    @unique
  user        String
  ip          String?
  userAgent   String?
  createdAt   DateTime  @default(now())
  expiresAt   DateTime
  revokedAt   DateTime?

  @@index([token])
  @@index([expiresAt])
}

model LoginAttempt {
  id          Int      @id @default(autoincrement())
  ip          String
  user        String?
  success     Boolean
  reason      String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([ip, createdAt])
  @@index([createdAt])
}

// ============================================================
// 電商商品（保護貼、手機殼、配件、二手機等）
// ============================================================
model Product {
  id            Int       @id @default(autoincrement())
  slug          String    @unique
  name          String
  category      String
  brand         String?
  description   String?
  imageUrl      String?
  imageUrls     String?
  price         Int       // 預設/起價（無變體時用此）
  comparePrice  Int?
  cost          Int?
  stock         Int       @default(0)  // 無變體時用此
  isActive      Boolean   @default(true)
  isFeatured    Boolean   @default(false)
  optionLabels  String?   // 規格標籤（如 "顏色,容量"）CSV
  metaTitle     String?
  metaDescription String?
  sortOrder     Int       @default(0)
  variants      ProductVariant[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([category])
  @@index([isActive])
  @@index([isFeatured])
}

// 商品規格變體（顏色/容量/尺寸 任意組合）
// product 可有 0-N 個 variant；有 variant 時 price/stock 用 variant 的
model ProductVariant {
  id            Int       @id @default(autoincrement())
  productId     Int
  product       Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  name          String    // 顯示名稱「黑色 128GB」
  optionValues  String?   // JSON: {"顏色":"黑","容量":"128GB"}
  price         Int
  comparePrice  Int?
  cost          Int?
  stock         Int       @default(0)
  sku           String?   @unique
  imageUrl      String?
  sortOrder     Int       @default(0)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([productId])
}

// ============================================================
// 自動產生的每週/每日報導文章
// ============================================================
model AutoArticle {
  id              Int      @id @default(autoincrement())
  slug            String   @unique
  kind            String   // "weekly_recycle" | "daily_repair" | "monthly_summary"
  title           String
  excerpt         String
  body            String
  coverImage      String?
  metaDescription String?
  keywords        String?  // CSV
  publishedAt     DateTime @default(now())
  createdAt       DateTime @default(now())

  @@index([kind])
  @@index([publishedAt])
}

model SiteSetting {
  id                    Int      @id @default(1)
  companyName           String   @default("i時代")
  legalName             String   @default("愛時代國際股份有限公司")
  taxId                 String   @default("42648769")
  phone                 String?
  lineId                String?  @default("@563amdnh")
  email                 String?  @default("admin@i-style.store")
  addressLine           String?
  city                  String   @default("新北市")
  district              String   @default("板橋區")
  postalCode            String?
  googleMapsUrl         String?
  googlePlaceId         String?
  latitude              Float?
  longitude             Float?
  businessHours         String?
  metaTitle             String?
  metaDescription       String?
  metaKeywords          String?
  cerphoneMarkupRate    Float    @default(1.15)
  oemMarkupRate         Float    @default(1.5)
  priceRoundingUnit     Int      @default(100)
  // 二手回收：若有 Apple 官方價，最終報價 = 官方 × (1 + this)
  recycleOfficialMargin Float    @default(0.4)
  // 二手回收：無官方價時，從同業最低價打折（0.85 = 我們收 85% 同業最低價）
  recycleCompetitorDiscount Float @default(0.85)
  updatedAt             DateTime @updatedAt
}

// ============================================================
// 二手回收：每日從 3 個來源爬取，取最低價
// 來源資訊不對外顯示
// ============================================================

model RecyclePrice {
  id              Int      @id @default(autoincrement())
  modelKey        String   @unique
  category        String
  brand           String
  modelName       String
  storage         String?
  variant         String?
  // 同業來源價（內部用，不外露）
  source1Price    Int?
  source1At       DateTime?
  source2Price    Int?
  source2At       DateTime?
  source3Price    Int?
  source3At       DateTime?
  // Apple 官方收購參考價（重要 anchor，避免虧本收）
  officialPrice   Int?
  officialAt      DateTime?
  // 對外顯示（取 Apple 官方 × ratio + 同業最低之合理值）
  minPrice        Int?
  manualOverride  Int?     // 後台可手動覆寫
  isAvailable     Boolean  @default(true)
  searchKeywords  String?
  sortOrder       Int      @default(0)
  lastUpdatedAt   DateTime @updatedAt
  createdAt       DateTime @default(now())

  @@index([category])
  @@index([brand])
  @@index([minPrice])
}

model RecycleScrapeLog {
  id          Int      @id @default(autoincrement())
  source      String   // "source1" | "source2" | "source3"
  status      String   // "success" | "error"
  recordCount Int      @default(0)
  errorMsg    String?
  durationMs  Int?
  startedAt   DateTime
  finishedAt  DateTime @default(now())
}

// ============================================================
// 自建流量分析（替代 GA / Vercel Analytics 的後台 view）
// ============================================================
model PageView {
  id         Int      @id @default(autoincrement())
  path       String   // "/shop/p-15"
  referrer   String?  // "https://www.google.com/" 或 "(direct)"
  utmSource  String?
  utmMedium  String?
  utmCampaign String?
  sessionId  String   // 30 分鐘活躍 session id（cookie）
  ipHash     String?  // SHA-256(ip + salt) 隱私保護
  country    String?  // 從 Vercel headers 取
  city       String?
  device     String?  // mobile | tablet | desktop
  browser    String?
  os         String?
  createdAt  DateTime @default(now())

  @@index([path])
  @@index([sessionId])
  @@index([createdAt])
}

// 自定義行為事件（加購、選規格、按 LINE…）
model AnalyticsEvent {
  id         Int      @id @default(autoincrement())
  name       String   // "add_to_cart" | "variant_selected" | "contact_line"
  path       String?  // 觸發頁面
  sessionId  String
  data       String?  // JSON：商品/規格/金額等
  createdAt  DateTime @default(now())

  @@index([name, createdAt])
  @@index([sessionId])
  @@index([createdAt])
}

// ============================================================
// 維修進度查詢（客人輸入單號 + 手機末 4 碼查得到）
// ============================================================
model RepairTicket {
  id              Int      @id @default(autoincrement())
  ticketNumber    String   @unique  // 取件單號 (e.g. "R26042701")
  customerName    String
  phoneLast4      String   // 手機末 4 碼，當查詢密碼用（不存全號）
  deviceModel     String   // 例如 "iPhone 15 Pro"
  issueDescription String   // 客人陳述問題
  status          String   @default("RECEIVED")
  // RECEIVED / DIAGNOSING / AWAITING_PARTS / REPAIRING / DONE / PICKED_UP / CANCELLED
  estimatedCost   Int?     // NT$ 估價
  finalCost       Int?     // 實際收費
  estimatedDoneAt DateTime?
  pickedUpAt      DateTime?
  // 進度時間軸（JSON array）：[{at: ISO, status: "DIAGNOSING", note: "...", photos: [url]}]
  timeline        String   @default("[]")
  internalNotes   String?  // 店家內部備註，不對客人顯示
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([ticketNumber])
  @@index([phoneLast4])
  @@index([createdAt])
}

// ============================================================
// 維修真實案例（SEO + 信任）
// ============================================================
model CaseStudy {
  id            Int      @id @default(autoincrement())
  slug          String   @unique
  title         String
  brand         String   // "Apple" / "Samsung" / ...
  deviceModel   String   // "iPhone 15 Pro Max"
  issueType     String   // "螢幕破裂" / "電池更換" / "進水"
  description   String   // Markdown
  beforePhotos  String   @default("[]")  // JSON array URLs
  afterPhotos   String   @default("[]")
  repairMinutes Int?
  cost          Int?
  customerInitial String?  // "謝先生"
  isPublished   Boolean  @default(true)
  publishedAt   DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([slug])
  @@index([brand])
  @@index([publishedAt])
}
